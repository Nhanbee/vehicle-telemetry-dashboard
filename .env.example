# Copy this file to .env and replace every CHANGE_ME value.
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=CHANGE_ME_STRONG_INFLUXDB_PASSWORD
INFLUXDB_TOKEN=CHANGE_ME_LONG_RANDOM_INFLUXDB_TOKEN
INFLUXDB_ORG=vehicle-prj
INFLUXDB_BUCKET=vehicle-data

# For the initial installation, use the same value as INFLUXDB_TOKEN.
GRAFANA_INFLUXDB_TOKEN=CHANGE_ME_LONG_RANDOM_INFLUXDB_TOKEN
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD

# Used only to encrypt Node-RED's local credential file.
NODE_RED_CREDENTIAL_SECRET=CHANGE_ME_DIFFERENT_LONG_RANDOM_SECRET
NODE_RED_INFLUXDB_CONFIG_ID=2ff91cc88122875c

# ESP32 WebSocket address visible from the Docker host.
ESP32_WS_URL=ws://192.168.0.100/ws
